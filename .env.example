# e.l.p- スクリプト用の環境変数テンプレート。
# このファイルを .env にコピーして値を埋める（.env は git 管理外）。
#   cp .env.example .env

# INNOVERA PBX（ホストは公開情報。APIキーは API一覧.md の保管場所参照）
INNOVERA_HOST=pbdxa17.innov-era.com
INNOVERA_API_KEY=

# Google / Gemini（GOOGLE_API_KEY は Gemini ブロック済み。文字起こしは GEMINI_API_KEY を使う）
GOOGLE_API_KEY=
GEMINI_API_KEY=

# Supabase（Project Settings > API / Database）
ELP_SUPABASE_URL=https://xhkcptfyjdbilhrpwcau.supabase.co
ELP_SUPABASE_ANON_KEY=
ELP_SUPABASE_SERVICE_ROLE_KEY=
ELP_SUPABASE_DB_PASSWORD=

# LINE Messaging API（LINE Developers > チャネル）
ELP_LINE_CHANNEL_SECRET=
ELP_LINE_CHANNEL_ACCESS_TOKEN=

# リマインドcronの手動起動に使う共有シークレット（Vercelの CRON_SECRET と同値）
ELP_CRON_SECRET=
